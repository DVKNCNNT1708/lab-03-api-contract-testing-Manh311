    {
      "name": "01_Functional",
      "item": [
        {
          "name": "GET getCardInfo",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Mã trạng thái là 200', function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test('Phản hồi tuân thủ lược đồ CardInfo', function () {\r",
                  "    const json = pm.response.json();\r",
                  "    pm.expect(json).to.have.property('cardId');\r",
                  "    pm.expect(json).to.have.property('holderName');\r",
                  "    pm.expect(json).to.have.property('status');\r",
                  "    pm.expect(['ACTIVE', 'BLOCKED', 'EXPIRED']).to.include(json.status); \r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
